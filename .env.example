# Application port (default: 3000)
PORT=3000

# Base URL used for SEO meta tags, sitemap, and RSS feed generation
BASE_URL=http://localhost:3000

# Blog metadata
NEXT_PUBLIC_SITE_NAME=My Next.js Blog
NEXT_PUBLIC_SITE_DESCRIPTION=A high-performance, SEO-optimized blog built with Next.js and MDX
NEXT_PUBLIC_SITE_AUTHOR=Your Name
